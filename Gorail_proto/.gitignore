# =============================================================================
# Unity
# =============================================================================

# 자동 생성되는 폴더 (Unity가 재생성)
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# MemoryCaptures - Profiler 메모리 스냅샷
[Mm]emoryCaptures/

# Recorded video - Unity Recorder 출력물
[Rr]ecordings/

# Asset meta data는 협업에 필수이므로 무시하지 않음
# (Assets/ 하위의 .meta 파일은 반드시 커밋해야 함)

# Autogenerated VS/Rider 프로젝트 파일 (Unity가 재생성)
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D 빌드 결과물
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics 생성 파일
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# =============================================================================
# JetBrains Rider
# =============================================================================

.idea/
*.sln.iml

# =============================================================================
# Visual Studio Code
# =============================================================================

# 개인 설정은 무시, 팀 공용 설정만 선택적으로 커밋
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# VS Code 로컬 히스토리
.history/
.ionide/

# =============================================================================
# OS 생성 파일
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# =============================================================================
# 기타
# =============================================================================

# 환경 변수 / 민감 정보
.env
.env.local
*.pem
*.key

# 백업 파일
*.bak
*.orig
*.swp
*.swo
# 플레이테스트 스크린샷(자동 생성, 추적 제외)
/[Aa]ssets/Screenshots/
/[Aa]ssets/Screenshots.meta
